{
    "name": "simpleICP (all languages)",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "runArgs": [
        "--cap-add=SYS_PTRACE",
        "--security-opt", "seccomp=unconfined",
        "--network=host",
        "-e", "DISPLAY=${localEnv:DISPLAY}",
        "-v", "/tmp/.X11-unix:/tmp/.X11-unix:rw"
    ],
    "containerEnv": {
        "VCPKG_ROOT": "/opt/vcpkg"
    },
    "mounts": [
        "source=${localEnv:HOME}/.matlab,target=/home/vscode/.matlab,type=bind,consistency=cached"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "llvm-vs-code-extensions.vscode-clangd",
                "ms-vscode.cmake-tools",
                "ms-python.python",
                "ms-python.black-formatter",
                "rust-lang.rust-analyzer",
                "tamasfe.even-better-toml",
                "julialang.language-julia",
                "toasty-technologies.octave",
                "MathWorks.language-matlab"
            ],
            "settings": {
                "files.watcherExclude": {
                    "**/c++/build/**": true,
                    "**/rust/target/**": true,
                    "**/python/build/**": true,
                    "**/python/dist/**": true
                },
                "clangd.arguments": [
                    "--compile-commands-dir=${workspaceFolder}/c++/build",
                    "--background-index",
                    "--header-insertion=never"
                ]
            }
        }
    },
    "postCreateCommand": "pip3 install --user --break-system-packages -e python && cmake -S c++ -B c++/build -DCMAKE_TOOLCHAIN_FILE=$VCPKG_ROOT/scripts/buildsystems/vcpkg.cmake -DCMAKE_EXPORT_COMPILE_COMMANDS=ON -DCMAKE_BUILD_TYPE=Release",
    "remoteUser": "vscode"
}
